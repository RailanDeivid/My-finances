COMPOSE_PROJECT_NAME=my-finances
WEBHOOK_SECRET=substitua-por-chave-forte

# Django
SECRET_KEY=substitua-por-uma-chave-longa-e-aleatoria
DEBUG=False
ALLOWED_HOSTS=myfinances.railandeivid.com.br

# Banco de dados
POSTGRES_DB=myfinancesDB
POSTGRES_USER=postgres
POSTGRES_PASSWORD=substitua-por-senha-forte
DB_HOST=db
DB_PORT=5432

# Redis
REDIS_URL=redis://redis:6379/0

# OpenAI
OPENAI_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OPENAI_TEMPERATURE=0.2

# Evolution API (WhatsApp)
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_INSTANCE_NAME=myfinances
EVOLUTION_API_KEY=substitua-por-chave-forte

# Cloudflare Tunnel (obtido no painel Zero Trust > Tunnels)
TUNNEL_TOKEN=substitua-pelo-token-do-cloudflare
